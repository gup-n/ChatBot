# ============================================================
# 网安学院问答机器人 · 环境变量配置模板
# 复制此文件为 .env，填入你的实际配置
# ============================================================

# --- LLM 配置 ---
# 模型提供商: deepseek | ollama
LLM_PROVIDER=deepseek

# DeepSeek API 配置（LLM_PROVIDER=deepseek 时必填）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-v4-falsh
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama 配置（LLM_PROVIDER=ollama 时必填）
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_BASE_URL=http://localhost:11434

# --- 嵌入模型配置 ---
# 嵌入模型提供商: huggingface | deepseek
EMBEDDING_PROVIDER=huggingface

# HuggingFace 嵌入模型（默认 bge-small-zh-v1.5，轻量中文）
HF_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# HuggingFace 镜像（国内用户建议使用 hf-mirror.com 加速下载）
HF_ENDPOINT=https://hf-mirror.com

# DeepSeek Embedding API（EMBEDDING_PROVIDER=deepseek 时使用）
# DEEPSEEK_EMBEDDING_MODEL=deepseek-text-embedding

# --- 向量数据库 ---
CHROMA_PERSIST_DIR=data/chroma_db

# --- 数据库 ---
SQLITE_DB_PATH=data/chatbot.db

# --- 知识库 ---
KNOWLEDGE_DIR=data/raw

# --- 检索配置 ---
RETRIEVAL_TOP_K=6
RETRIEVAL_SCORE_THRESHOLD=0.3

# --- 上下文配置 ---
MAX_CONTEXT_MESSAGES=50
MAX_AGENT_ITERATIONS=5

# --- 知识库概述（用于路由节点判断知识库范围）---
KB_OVERVIEW=本知识库涵盖：宁波工程学院网安学院的学院概况、师资队伍、人才培养、教务办事等相关内容。
