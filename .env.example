# ============================================================
# 网安学院问答机器人 · 环境变量配置模板
# 复制为 .env 后填写密钥；修改后通常需要重启后端。
# ============================================================

# --- 模型配置（管理端保存时自动维护）---
# 当前启用的提供商：openai_compatible | ollama
LLM_PROVIDER=openai_compatible
# 所有 LLM 配置。OpenAI 兼容接口可填写 DeepSeek / OpenAI / vLLM 等地址。
LLM_SETTINGS={"openai_compatible":{"api_key":"","model":"deepseek-v4-flash","base_url":"https://api.deepseek.com"},"ollama":{"model":"qwen2.5:7b","base_url":"http://localhost:11434"}}
# 当前嵌入提供商：huggingface | openai_compatible | ollama
EMBEDDING_PROVIDER=huggingface
# Ollama Embedding 建议使用专用模型 nomic-embed-text，而非聊天模型。
EMBEDDING_SETTINGS={"huggingface":{"model":"BAAI/bge-large-zh-v1.5"},"openai_compatible":{"api_key":"","model":"text-embedding-3-small","base_url":"https://api.openai.com/v1"},"ollama":{"model":"nomic-embed-text","base_url":"http://localhost:11434"}}
HF_ENDPOINT=https://hf-mirror.com

# --- 安全与管理员初始化 ---
# 必须是至少 32 位的随机字符串；请勿提交到 Git。
JWT_SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
# 仅在数据库中尚不存在该管理员时生效；留空则不会创建管理员。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-initial-password
# 可访问 API 的浏览器来源，逗号分隔。
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:8502,http://127.0.0.1:8502
JWT_TOKEN_EXPIRE_HOURS=24

# --- 数据位置 ---
CHROMA_PERSIST_DIR=data/chroma_db
SQLITE_DB_PATH=data/chatbot.db
KNOWLEDGE_DIR=data/raw

# --- 知识库载入与检索 ---
# 上传限制：文件数量、单文件字节数、单批总字节数。
MAX_UPLOAD_FILES=50
MAX_UPLOAD_BYTES=10485760
MAX_UPLOAD_TOTAL_BYTES=104857600
MAX_FETCH_BYTES=5242880
# 检索返回数量与 Chroma 距离阈值（越小越严格）。
RETRIEVAL_TOP_K=6
# 检索模式：hybrid（向量 + BM25，推荐）或 vector（仅向量）。
RETRIEVAL_MODE=hybrid
RETRIEVAL_SCORE_THRESHOLD=0.3
# 切片策略；修改后必须重建向量索引。
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_SEPARATORS=["\n\n","\n","。","，"," ",""]
MAX_CONTEXT_MESSAGES=50
MAX_CHAT_MESSAGE_CHARS=4000
KB_OVERVIEW=本知识库涵盖：宁波工程学院网安学院的学院概况、师资队伍、人才培养、教务办事等相关内容。

# --- 模型与 HTTP 性能调优 ---
LLM_TEMPERATURE=0.7
LLM_STREAM_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
EMBEDDING_TIMEOUT_SECONDS=120
MODEL_LIST_TIMEOUT_SECONDS=15
URL_FETCH_TIMEOUT_SECONDS=20
URL_FETCH_CONNECT_TIMEOUT_SECONDS=5
HTTP_CLIENT_TIMEOUT_SECONDS=300
AUDIT_LOG_MAX_PAGE_SIZE=200

# --- 本地启动（run.py 使用）---
APP_HOST=0.0.0.0
API_PORT=8000
ADMIN_PORT=8501
USER_PORT=8502
